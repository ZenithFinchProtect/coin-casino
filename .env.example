# Discord OAuth application (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Optional: OAuth callback URL. Derived from the request origin when unset.
DISCORD_REDIRECT_URI=

# Long random string used to sign session cookies.
SESSION_SECRET=

# The status-coin-bot coin API (its public URL) and the shared API key.
BOT_API_BASE=
CASINO_API_KEY=
